{
  "id": "skillnest-env",
  "name": "SkillNest — Local",
  "values": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "default",
      "enabled": true
    },
    {
      "key": "authToken",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Paste your Clerk JWT token here. Get it from browser DevTools > Application > Cookies > __session, or use Clerk's getToken() method."
    },
    {
      "key": "courseId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "MongoDB ObjectId of a course. Copy from the GET /api/courses response."
    },
    {
      "key": "reviewId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "MongoDB ObjectId of a review."
    },
    {
      "key": "blogSlug",
      "value": "nextjs-14-app-router-guide",
      "type": "default",
      "enabled": true,
      "description": "Slug of a seeded blog post."
    }
  ],
  "_postman_variable_scope": "environment"
}
